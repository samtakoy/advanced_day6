# =============================================================
# API Keys
# =============================================================

# OpenRouter — агрегатор: поддерживает OpenAI, Anthropic и другие модели.
# Если задан, SkyHelper идёт через OpenRouter и автоматически префиксует
# модель как openai/<model>. НЕ задавать вместе с OLLAMA_BASE_URL.
# OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI напрямую — альтернатива OpenRouter. Также нужен для fine-tuning jobs.
# OPENAI_API_KEY=sk-proj-...


# =============================================================
# SkyHelper (:8000)
# =============================================================

# Модель. gpt-4o-mini — проверенный вариант (другие не тестировались).
# С OpenRouter можно указать провайдер явно: openai/gpt-4o-mini
# SKYHELPER_MODEL=gpt-4o-mini

# Bearer-токен для /chat. Если не задан — auth выключен (dev-режим, warning в лог).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(24))"
# SKYHELPER_BEARER_TOKEN=...

# Заморозить настройки безопасности на сервере: hardened / sanitize=on / validate=on.
# true  — боевой режим, клиент не может переключить (по умолчанию).
# false — dev-режим, переключатели в UI активны.
# SKYHELPER_LOCK_SETTINGS=true

# Rate-limit (дефолты обычно подходят)
# SKYHELPER_RATE_LIMIT_PER_TOKEN=30
# SKYHELPER_RATE_LIMIT_PER_USER=30
# SKYHELPER_RATE_LIMIT_WINDOW=60

# URL Gateway-прокси (при use_gateway: true)
# SKYHELPER_GATEWAY_URL=http://localhost:8001


# =============================================================
# Gateway (:8001)
# =============================================================

# Полное логирование: пишет messages_full и response_full в gateway/logs/audit.jsonl.
# Нужно для наблюдения за тем что реально уходит в LLM.
# GATEWAY_LOG_FULL=false

# Rate-limit per IP
# GATEWAY_RATE_LIMIT=20
# GATEWAY_RATE_WINDOW=60

# Ollama — локальная LLM. Если задан, Gateway использует Ollama вместо OpenRouter/OpenAI.
# При этой конфигурации OPENROUTER_API_KEY НЕ задавать:
# иначе SkyHelper добавит префикс openai/ к имени модели и Ollama его не поймёт.
# OLLAMA_BASE_URL=http://localhost:11434/v1


# =============================================================
# Готовые конфигурации — раскомментировать нужный блок
# =============================================================

# --- OpenRouter (стандартный режим) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# SKYHELPER_MODEL=gpt-4o-mini

# --- Red Team сессия ---
# OPENROUTER_API_KEY=sk-or-v1-...
# SKYHELPER_MODEL=gpt-4o-mini
# SKYHELPER_BEARER_TOKEN=<сгенерировать>
# SKYHELPER_LOCK_SETTINGS=true

# --- Локальная разработка (OpenAI, защиты выключены) ---
# OPENAI_API_KEY=sk-proj-...
# SKYHELPER_MODEL=gpt-4o-mini
# SKYHELPER_LOCK_SETTINGS=false

# --- Gateway + Ollama ---
# SKYHELPER_MODEL=<имя-модели-в-ollama>
# OLLAMA_BASE_URL=http://localhost:11434/v1
# (OPENROUTER_API_KEY не задавать)
