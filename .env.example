# One of the two is enough.
# - OpenRouter: proxies OpenAI + Anthropic + others under one key.
#   Supports baseline + synthetic generation. Does NOT support fine-tuning jobs.
# - Direct OpenAI: required for actually running fine_tuning.jobs.create (Day 7+).
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-proj-...

# Optional, for direct Anthropic use in synthetic generation (OpenRouter covers it anyway).
ANTHROPIC_API_KEY=sk-ant-...
