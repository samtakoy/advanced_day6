{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StepData",
  "description": "Persisted state of a single step within a task. Stored at .tasks/<task_id>/step_NN.json in variant B.",
  "type": "object",
  "properties": {
    "task_id": {"type": "string"},
    "n": {"type": "integer", "minimum": 1},
    "goal": {"type": "string"},
    "preconds": {
      "type": "array",
      "items": {"type": "string"}
    },
    "checklist": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "action_hint": {"type": "string"},
    "success_criteria": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["TODO", "IN_PROGRESS", "DONE", "FAILED", "NEEDS_REPLAN"]
    },
    "result": {
      "type": ["string", "null"],
      "description": "Populated after step_update_result."
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "required": ["task_id", "n", "goal", "checklist", "action_hint", "success_criteria", "status"]
}
